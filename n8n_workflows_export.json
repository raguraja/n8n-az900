        {
          "id": "aa002",
          "name": "Load Config",
          "type": "n8n-nodes-base.code",
          "typeVersion": 2,
          "position": [
            420,
            300
          ],
          "parameters": {
            "jsCode": "\n// Trigger: just pass a single item to start the chain\nreturn [{ json: { triggered: true } }];\n",
            "mode": "runOnceForAllItems"
          }
        },
        {
          "id": "aa004",
          "name": "Search & Filter",
          "type": "n8n-nodes-base.code",
          "typeVersion": 2,
          "position": [
            860,
            300
          ],
          "parameters": {
            "jsCode": "\nconst fs            = require('fs');\nconst { spawnSync } = require('child_process');\nconst os            = require('os');\nconst path          = require('path');\n\nconst CONFIG_PATH = 'C:\\\\Users\\\\RAGU\\\\nellis_data\\\\config.json';\nconst STATE_PATH  = 'C:\\\\Users\\\\RAGU\\\\nellis_data\\\\state.json';\nconst TMP_FILE    = path.join(os.tmpdir(), 'nellis_n8n_items.json');\n\nconst cfg     = JSON.parse(fs.readFileSync(CONFIG_PATH, 'utf8'));\nconst state   = fs.existsSync(STATE_PATH) ? JSON.parse(fs.readFileSync(STATE_PATH, 'utf8')) : { favorited: {}, removed_ids: [] };\nconst already = new Set(Object.keys(state.favorited || {}));\nconst removed = new Set(state.removed_ids || []);\nconst searches = cfg.searches || [];\n\nif (!searches.length) return [{ json: { newItems: [], newCount: 0, totalFound: 0, searchCount: 0, tmpFile: TMP_FILE, statePath: STATE_PATH } }];\n\nfunction titleWords(str) {\n  return str.toLowerCase().split(/[^a-z0-9]+/).filter(Boolean);\n}\nfunction wordMatch(sw, tw) {\n  if (sw === tw) return true;\n  if (Math.min(sw.length, tw.length) < 4) return false;\n  return tw.startsWith(sw) || sw.startsWith(tw);\n}\nfunction matchesKeyword(title, keyword) {\n  const sWords = keyword.toLowerCase().split(/\\s+/).filter(Boolean);\n  if (sWords.length === 0) return false;\n  const tWords = titleWords(title);\n  return sWords.every(sw => tWords.some(tw => wordMatch(sw, tw)));\n}\nfunction decodeHtml(str) {\n  return str\n    .replace(/&amp;/g, '&').replace(/&quot;/g, '\"')\n    .replace(/&#39;/g, \"'\").replace(/&lt;/g, '<')\n    .replace(/&gt;/g, '>').replace(/&nbsp;/g, ' ');\n}\n\nconst seen     = new Set();\nconst newItems = [];\nlet totalFound = 0;\n\nfor (const s of searches) {\n  const keywords = s.keywords || '';\n  if (!keywords) continue;\n\n  const url = 'https://www.nellisauction.com/search?query=' + encodeURIComponent(keywords) ;\n  let html = '';\n  try {\n    // Step 1: get session cookie\n    const cookieFile = path.join(os.tmpdir(), 'nellis_cookies.txt');\n    spawnSync('curl', ['-s', '-c', cookieFile, '-o', 'NUL', '-A', 'Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36', 'https://www.nellisauction.com/'], { timeout: 15000 });\n    // Step 2: POST Dallas location (id=8)\n    spawnSync('curl', ['-s', '-b', cookieFile, '-c', cookieFile, '-X', 'POST', '-d', 'shoppingLocationId=8&referrer=/search', '-o', 'NUL', '-A', 'Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36', 'https://www.nellisauction.com/change-shopping-location'], { timeout: 15000 });\n    // Step 3: Search with Dallas cookie\n    const cr = spawnSync('curl', ['-s', '-L', '--max-time', '20', '-b', cookieFile, '-A', 'Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36', url], { timeout: 25000, encoding: 'utf8' });\n    html = cr.stdout || '';\n  } catch(e) {\n    continue;\n  }\n\n  // Parse item cards: href=\"/p/slug/oid\" immediately followed by <h6>Title</h6>\n  const pattern = /href=\"(\\/p\\/[^\"]+\\/(\\d+))\"[^>]*><h6[^>]*>([^<]+)<\\/h6>/g;\n  let m;\n  while ((m = pattern.exec(html)) !== null) {\n    const href  = m[1];\n    const oid   = m[2];\n    const title = decodeHtml(m[3]).trim();\n    totalFound++;\n\n    if (!oid || seen.has(oid))            continue;\n    if (already.has(oid))                 continue;\n    if (removed.has(oid))                 continue;\n    if (!matchesKeyword(title, keywords)) continue;\n\n    seen.add(oid);\n    newItems.push({\n      oid,\n      title: title.substring(0, 60),\n      url:   'https://www.nellisauction.com' + href,\n      retail: '?',\n    });\n  }\n}\n\nfs.writeFileSync(TMP_FILE, JSON.stringify(newItems), 'utf8');\n\nreturn [{ json: { newItems, newCount: newItems.length, totalFound, searchCount: searches.length, tmpFile: TMP_FILE, statePath: STATE_PATH } }];\n",
            "mode": "runOnceForAllItems"
          }
        },
        {
          "id": "aa005",
          "name": "Playwright: Favorite Items",
          "type": "n8n-nodes-base.code",
          "typeVersion": 2,
          "position": [
            1080,
            300
          ],
          "parameters": {
            "jsCode": "\nconst fs      = require('fs');\nconst { spawn } = require('child_process');\n\nconst newCount = $('Search & Filter').first().json.newCount;\nconst tmpFile  = 'C:\\\\Users\\\\RAGU\\\\AppData\\\\Local\\\\Temp\\\\nellis_n8n_items.json';\n\nif (newCount === 0) {\n  return [{ json: { stdout: '{\"added\":[],\"failed\":[]}', background: false } }];\n}\n\n// Spawn detached \u00e2\u20ac\u201d returns immediately, no timeout risk\nconst proc = spawn(\n  'python',\n  ['C:\\\\Users\\\\RAGU\\\\nellis_playwright.py', tmpFile, '--notify'],\n  { detached: true, stdio: 'ignore', windowsHide: true }\n);\nproc.unref();\n\nreturn [{ json: { stdout: JSON.stringify({ spawned: true, pid: proc.pid, items: newCount }), background: true } }];\n",
            "mode": "runOnceForAllItems"
          }
        },
        {
          "id": "aa006",
          "name": "Update State & Format Message",
          "type": "n8n-nodes-base.code",
          "typeVersion": 2,
          "position": [
            1300,
            300
          ],
          "parameters": {
            "jsCode": "\nconst fs        = require('fs');\nconst STATE_PATH = 'C:\\\\Users\\\\RAGU\\\\nellis_data\\\\state.json';\nconst TMP_FILE   = 'C:\\\\Users\\\\RAGU\\\\AppData\\\\Local\\\\Temp\\\\nellis_n8n_items.json';\n\nconst searchData = $('Search & Filter').first().json;\nconst pwData     = $input.first().json;\nconst rawStdout  = pwData.stdout || '{}';\nconst background = pwData.background === true;\n\nlet added = [], failed = [];\ntry {\n  const parsed = JSON.parse(rawStdout);\n  if (parsed.spawned) {\n    // Background mode: read tmp file to know what was queued\n    const queued = fs.existsSync(TMP_FILE) ? JSON.parse(fs.readFileSync(TMP_FILE, 'utf8')) : [];\n    const state  = fs.existsSync(STATE_PATH) ? JSON.parse(fs.readFileSync(STATE_PATH, 'utf8')) : { favorited: {}, removed_ids: [] };\n    // Don't update state here \u00e2\u20ac\u201d nellis_playwright.py --notify will do it directly\n    const msg = `Nellis Auto-Favorite\\nSearches: ${searchData.searchCount} | Found: ${searchData.totalFound} | Matched: ${searchData.newCount}\\nFavoriting ${queued.length} item(s) in background (PID ${parsed.pid})`;\n    return [{ json: { message: msg, addedCount: queued.length, hasError: false } }];\n  }\n  added  = parsed.added  || [];\n  failed = parsed.failed || [];\n} catch(e) {\n  failed = [{ reason: 'parse error: ' + rawStdout.substring(0, 100) }];\n}\n\n// Inline (non-background) path: update state directly\nconst newItems = searchData.newItems || [];\nconst state    = fs.existsSync(STATE_PATH) ? JSON.parse(fs.readFileSync(STATE_PATH, 'utf8')) : { favorited: {}, removed_ids: [] };\nstate.favorited = state.favorited || {};\nstate.last_run  = new Date().toISOString();\n\nlet addedCount = 0;\nfor (const item of newItems) {\n  const wasAdded = added.find(a => a.oid === item.oid && !a.skipped);\n  if (wasAdded) {\n    state.favorited[item.oid] = { title: item.title, url: item.url, retail: item.retail, added_at: new Date().toISOString() };\n    addedCount++;\n  }\n}\n\nfs.writeFileSync(STATE_PATH, JSON.stringify(state, null, 2), 'utf8');\n\nconst skipped = added.filter(a => a.skipped).length;\nconst msg = `Nellis Auto-Favorite\\nSearches: ${searchData.searchCount} | Found: ${searchData.totalFound} | Matched: ${searchData.newCount}\\nAdded: ${addedCount} | Already saved: ${skipped} | Failed: ${failed.length}\\n`;\nreturn [{ json: { message: msg, addedCount, hasError: failed.length > 0 } }];\n",
            "mode": "runOnceForAllItems"
          }
        },

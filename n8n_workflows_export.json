        {
          "parameters": {
            "jsCode": "\nconst fs = require('fs');\nconst STATE_PATH   = 'C:\\\\Users\\\\RAGU\\\\nellis_data\\\\state.json';\nconst BID_MAP_PATH = 'C:\\\\Users\\\\RAGU\\\\nellis_bid_map.json';\nconst PENDING_PATH = 'C:\\\\Users\\\\RAGU\\\\nellis_data\\\\bid_pending.json';\n\nconst state = fs.existsSync(STATE_PATH)\n  ? JSON.parse(fs.readFileSync(STATE_PATH, 'utf8'))\n  : { favorited: {} };\n\nconst favs = Object.entries(state.favorited || {});\n\n// Build bid map for daemon to use later\nconst bidMap = {};\nfavs.forEach(([oid, item], i) => {\n  bidMap[String(i + 1)] = { oid, title: item.title || oid, url: item.url || '', retail: item.retail ?? '?' };\n});\nfs.writeFileSync(BID_MAP_PATH, JSON.stringify(bidMap, null, 2), 'utf8');\n\n// Save pending confirmation flag\nfs.writeFileSync(PENDING_PATH, JSON.stringify({ pending: true, sent_at: new Date().toISOString() }), 'utf8');\n\nconst count = favs.length;\nlet msg = 'Nellis \u2014 Bidding starts soon\\n\\n';\nif (count === 0) {\n  msg += 'Watchlist is empty \u2014 nothing to bid on tonight.';\n} else {\n  msg += `${count} item(s) on watchlist. Bid $5 on all unless you replied overrides earlier.\\n\\n`;\n  favs.forEach(([oid, item], i) => {\n    const retail = item.retail && item.retail !== '?' ? ` ($${item.retail} retail)` : '';\n    msg += `${i + 1}. ${(item.title || oid).substring(0, 50)}${retail}\\n`;\n  });\n  msg += '\\nProceed with bidding?';\n}\n\nreturn [{ json: { message: msg, count } }];\n"
